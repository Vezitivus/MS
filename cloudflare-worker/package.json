{
  "name": "vezitivus-ms-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create vezitivus-ms-db --location eeur",
    "db:migrate:local": "wrangler d1 migrations apply vezitivus-ms-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply vezitivus-ms-db --remote",
    "db:check": "wrangler d1 execute vezitivus-ms-db --remote --command=\"SELECT name FROM sqlite_schema WHERE type='table' ORDER BY name;\"",
    "migrate:google": "node scripts/migrate-from-google.mjs"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
